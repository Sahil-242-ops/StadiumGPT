{
  "name": "@stadiumgpt/backend",
  "version": "1.0.0",
  "private": true,
  "description": "StadiumGPT — Express.js API backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && npm run copy-data",
    "copy-data": "node -e \"const fs=require('fs');const p=require('path');const src=p.join('src','data');const dst=p.join('dist','src','data');fs.mkdirSync(dst,{recursive:true});fs.readdirSync(src).forEach(f=>fs.copyFileSync(p.join(src,f),p.join(dst,f)));console.log('Data files copied to dist/src/data/')\"",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "tsx": "^4.15.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
