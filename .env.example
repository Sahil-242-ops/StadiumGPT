# StadiumGPT — Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values (never commit .env to git)
# 3. On Vercel, set these in Project Settings → Environment Variables

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Backend (Express API) ────────────────────────────────────────────────────
APP_NAME=StadiumGPT
APP_VERSION=1.0.0
PORT=8080
NODE_ENV=development

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins. Use * for development only.
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Firebase (optional — for auth) ───────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
